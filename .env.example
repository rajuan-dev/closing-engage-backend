NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
# MONGODB_URI=mongodb://localhost:27017/closing-engage
MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/closing-engage?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=1d
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=change_this_admin_password
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET=closing-engage-storage
RESEND_API_KEY=re_example_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com
WEBSITE_BASE_URL=http://localhost:5173
LOG_LEVEL=info
